# Env example for the backend (copy to `backend/.env`).
# Keep your real .env file out of git (see root .gitignore).

# Tavily Research API (macro themes + theme driver enrichment). Uses `research` + polling, not `/search`.
# Note: the app supports both `TAVILY_*` and the legacy typo `TRAVILY_*` (either one works).
TAVILY_API_KEY=

# Max time to wait for a research job to finish (ms) and poll interval (ms).
TAVILY_RESEARCH_MAX_WAIT_MS=120000
TAVILY_RESEARCH_POLL_MS=2500
# Initial request timeout when starting a research task (seconds).
TAVILY_RESEARCH_START_TIMEOUT_S=120

# After a plan usage / quota error from Tavily, skip new research calls for this many ms (default 10m) to avoid spamming the API and logs.
TAVILY_QUOTA_BACKOFF_MS=600000

# Delay between each of the four `/macro-from-tavily` Research queries (ms). Parallel calls often hit "excessive requests" on starter plans; default 1200.
TAVILY_MACRO_AUTO_QUERY_GAP_MS=1200

# Optional pause (ms) before the theme narrative Research call when cache misses — set e.g. 1000 if you still see rate limits right after "Fetch macro" + industry refresh.
TAVILY_THEME_RESEARCH_PREFLIGHT_MS=0

# Set to 1 to disable all Tavily Research calls (Trendlyne + base themes only).
# TAVILY_DISABLE=1

# Macro query used for dynamic theme keyword extraction.
TAVILY_MACRO_QUERY=India macro trends sectors growth 2026 infrastructure demand sectoral themes India

# Hint appended to Tavily Research queries for `/macro-from-tavily` (India macro dashboards).
TAVILY_MACRO_AUTO_DOMAIN_HINT=indiamacroindicators.co.in

# Restrict sources (comma-separated hostnames).
TAVILY_INCLUDE_DOMAINS=moneycontrol.com,economictimes.indiatimes.com,business-standard.com,screener.in

# Cache TTL for generated themes (ms).
THEMES_CACHE_TTL_MS=7200000

# Exact URL ingestion (user-provided URLs/PDFs).
EXACT_SOURCE_TIMEOUT_MS=6000
EXACT_SOURCE_MAX_URLS=2
EXACT_SOURCE_MAX_PDF_PAGES=3
EXACT_SOURCE_MAX_CHARS=4000

# How strongly market + narrative overlap boosts final theme strength.
THEME_OVERLAP_BOOST_WEIGHT=0.2

# Market-trend signal timeouts/cache.
MARKET_SIGNALS_CACHE_TTL_MS=300000
MARKET_SIGNAL_TIMEOUT_MS=5000

# OpenAI (optional enrichment / keyword extraction / reason polishing).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=12000

# Recommendation reason polishing (optional).
ENABLE_REASON_POLISH=false
MAX_REASON_POLISH_PER_THEME=2

# Backend port.
PORT=3000

